@model List<PasswordGeneratorMvc.Models.PasswordEntry>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<div class="container mt-5">

    <h2 class="text-center mb-4">Password History</h2>

    <div class="text-end mb-3">
        <a class="btn btn-primary" href="/Password/Create">
            + Create
        </a>
    </div>

    <table class="table table-hover table-bordered align-middle">
        <thead class="table-dark">
            <tr>
                <th>Title</th>
                <th>Login</th>
                <th>Password</th>
                <th style="width: 260px;">Actions</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Title</td>
                    <td>@item.Login</td>
                    <td>
                        <code>@item.EncryptedPassword</code>
                    </td>
                    <td>

                        <button class="btn btn-outline-success btn-sm"
                                onclick="copy('@item.EncryptedPassword')">
                            Copy
                        </button>

                        <a class="btn btn-warning btn-sm"
                           href="/Password/Edit?id=@item.Id">
                            Edit
                        </a>

                        <button class="btn btn-danger btn-sm"
                                onclick="del('@item.Id')">
                            Delete
                        </button>

                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<script>
function copy(text){
    navigator.clipboard.writeText(text);
    alert("Copied");
}

function del(id){
    fetch('/Password/Delete?id=' + id, { method: 'POST' })
        .then(() => location.reload());
}
</script>